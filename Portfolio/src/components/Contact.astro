<section class="section-shell text-white px-6 md:px-12 lg:px-20 py-16 md:py-20" id="contact">

    <div class="max-w-xl mx-auto">
        <div class="text-center mb-10">
            <div class="w-16 h-16 rounded-full bg-gradient-to-br from-primary to-cyan-400 flex items-center justify-center mx-auto mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21.2 8.4c.5.38.8.97.8 1.6v10c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V10c0-.63.3-1.22.8-1.6l8-6a2 2 0 0 1 2.4 0l8 6Z"/>
                    <path d="m22 10-8.97 5.7a2 2 0 0 1-2.06 0L2 10"/>
                </svg>
            </div>
            <h2 class="font-bold text-3xl md:text-4xl mb-2">Contacto</h2>
            <p class="text-gray-400">¿Tienes un proyecto en mente? ¡Hablamos!</p>
        </div>

        <form id="contact-form" class="space-y-5">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div class="space-y-2">
                    <label for="name" class="text-sm font-medium text-gray-300">Nombre</label>
                    <input type="text" id="name" name="name" required placeholder="Tu nombre" 
                        class="w-full rounded-lg px-4 py-3 bg-white/5 border border-white/10 focus:border-primary focus:ring-1 focus:ring-primary transition-colors placeholder-gray-500 outline-none">
                </div>
                <div class="space-y-2">
                    <label for="email" class="text-sm font-medium text-gray-300">Email</label>
                    <input type="email" id="email" name="email" required placeholder="tu@email.com" 
                        class="w-full rounded-lg px-4 py-3 bg-white/5 border border-white/10 focus:border-primary focus:ring-1 focus:ring-primary transition-colors placeholder-gray-500 outline-none">
                </div>
            </div>

            <div class="space-y-2">
                <label for="subject" class="text-sm font-medium text-gray-300">Asunto</label>
                <select id="subject" name="subject" required 
                    class="w-full rounded-lg px-4 py-3 bg-white/5 border border-white/10 focus:border-primary focus:ring-1 focus:ring-primary transition-colors outline-none appearance-none cursor-pointer">
                    <option value="" disabled selected>Selecciona una opción</option>
                    <option value="General">Consulta general</option>
                    <option value="Project">Colaboración en proyecto</option>
                    <option value="Freelance">Oferta de trabajo freelance</option>
                    <option value="Feedback">Feedback</option>
                </select>
            </div>

            <div class="space-y-2">
                <label for="message" class="text-sm font-medium text-gray-300">Mensaje</label>
                <textarea id="message" name="message" required rows="5" placeholder="Cuéntame sobre tu proyecto..." 
                    class="w-full rounded-lg px-4 py-3 bg-white/5 border border-white/10 focus:border-primary focus:ring-1 focus:ring-primary transition-colors placeholder-gray-500 outline-none resize-none"></textarea>
            </div>

            <p id="contact-form-error" class="hidden text-sm text-red-400 text-center" role="alert"></p>

            <button type="submit" class="w-full px-6 py-4 bg-primary rounded-lg font-semibold text-lg hover:bg-primary/90 transition-colors flex items-center justify-center gap-2">
                <span>Enviar mensaje</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="m22 2-7 20-4-9-9-4Z"/>
                    <path d="M22 2 11 13"/>
                </svg>
            </button>
        </form>

        <div class="mt-10 pt-8 border-t border-white/10">
            <p class="text-center text-gray-400 mb-4">O encuéntrame en</p>
            <div class="flex justify-center gap-6">
                <a href="http://linkedin.com/in/seliaszg" target="_blank" class="w-12 h-12 rounded-full bg-white/5 border border-white/10 flex items-center justify-center hover:bg-white/10 hover:border-primary transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                    </svg>
                </a>
                <a href="https://github.com/sezgox" target="_blank" class="w-12 h-12 rounded-full bg-white/5 border border-white/10 flex items-center justify-center hover:bg-white/10 hover:border-primary transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                    </svg>
                </a>
            </div>
        </div>
    </div>

    <script is:inline src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>
    <script is:inline>
        emailjs.init({
            publicKey: 'OoCk41ZPwX1G-eb1c'
        });
        const template = 'template_1ll2us2';
        const serviceId = 'service_lklw8eq';
        const ownerEmail = 'elias.szg2000@gmail.com';

        function escapeHtml(s) {
            return String(s)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#039;');
        }

        /** HTML for notification to you; same template can use {{{message}}} as the ack. */
        function buildOwnerHtml(name, email, subject, body) {
            const h = escapeHtml;
            const bodyHtml = h(body).replace(/\r\n|\r|\n/g, '<br>');
            return (
                '<table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background:#f4f6f8;margin:0;padding:24px 12px;font-family:system-ui,-apple-system,sans-serif;">' +
                '<tr><td align="center">' +
                '<table role="presentation" width="100%" style="max-width:560px;background:#ffffff;border-radius:12px;border:1px solid #e2e8f0;">' +
                '<tr><td style="padding:22px 24px;background:#0f172a;">' +
                '<p style="margin:0;font-size:13px;font-weight:600;color:#f8fafc;">Nuevo mensaje · Portfolio</p>' +
                '</td></tr>' +
                '<tr><td style="padding:20px 24px;font-size:14px;color:#334155;line-height:1.5;">' +
                '<p style="margin:0 0 12px;"><strong>Nombre:</strong> ' + h(name) + '</p>' +
                '<p style="margin:0 0 12px;"><strong>Email:</strong> <a href="mailto:' + h(email) + '">' + h(email) + '</a></p>' +
                '<p style="margin:0 0 12px;"><strong>Asunto:</strong> ' + h(subject) + '</p>' +
                '<p style="margin:0 0 8px;"><strong>Mensaje:</strong></p>' +
                '<div style="padding:14px 16px;background:#f8fafc;border-radius:8px;border:1px solid #e2e8f0;font-size:14px;line-height:1.6;">' + bodyHtml + '</div>' +
                '</td></tr></table></td></tr></table>'
            );
        }

        /** HTML for user ack email; use {{{message}}} in EmailJS so it renders as HTML. */
        function setContactFormError(msg) {
            var el = document.getElementById('contact-form-error');
            if (!el) { return; }
            if (msg) {
                el.textContent = msg;
                el.classList.remove('hidden');
            } else {
                el.textContent = '';
                el.classList.add('hidden');
            }
        }

        function buildUserAckHtml(name, email, subject, body) {
            const h = escapeHtml;
            const bodyHtml = h(body).replace(/\r\n|\r|\n/g, '<br>');
            return (
                '<table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background:#f4f6f8;margin:0;padding:24px 12px;font-family:Georgia,\'Times New Roman\',serif;">' +
                '<tr><td align="center">' +
                '<table role="presentation" width="100%" style="max-width:560px;background:#ffffff;border-radius:14px;overflow:hidden;border:1px solid #e2e8f0;box-shadow:0 12px 40px rgba(15,23,42,0.08);">' +
                '<tr><td style="padding:28px 28px 20px;background:linear-gradient(135deg,#0f172a 0%,#1e293b 100%);">' +
                '<p style="margin:0;font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:#94a3b8;">Portfolio · Sergio Elías</p>' +
                '<h1 style="margin:10px 0 0;font-size:22px;font-weight:600;color:#f8fafc;line-height:1.25;">Gracias por tu mensaje</h1>' +
                '<p style="margin:12px 0 0;font-size:15px;line-height:1.55;color:#cbd5e1;">He recibido lo que nos enviaste. Te respondo en cuanto pueda.</p>' +
                '</td></tr>' +
                '<tr><td style="padding:24px 28px 8px;">' +
                '<p style="margin:0 0 12px;font-size:12px;font-weight:600;letter-spacing:0.06em;text-transform:uppercase;color:#64748b;">Resumen de lo enviado</p>' +
                '<table role="presentation" width="100%" style="font-size:14px;color:#334155;border-collapse:collapse;">' +
                '<tr><td style="padding:10px 0;border-bottom:1px solid #f1f5f9;width:100px;color:#64748b;vertical-align:top;">Nombre</td>' +
                '<td style="padding:10px 0;border-bottom:1px solid #f1f5f9;font-weight:500;">' + h(name) + '</td></tr>' +
                '<tr><td style="padding:10px 0;border-bottom:1px solid #f1f5f9;color:#64748b;vertical-align:top;">Email</td>' +
                '<td style="padding:10px 0;border-bottom:1px solid #f1f5f9;"><a href="mailto:' + h(email) + '" style="color:#0d9488;text-decoration:none;">' + h(email) + '</a></td></tr>' +
                '<tr><td style="padding:10px 0;border-bottom:1px solid #f1f5f9;color:#64748b;vertical-align:top;">Asunto</td>' +
                '<td style="padding:10px 0;border-bottom:1px solid #f1f5f9;">' + h(subject) + '</td></tr>' +
                '</table></td></tr>' +
                '<tr><td style="padding:0 28px 28px;">' +
                '<div style="margin-top:8px;padding:16px 18px;background:#f8fafc;border-radius:10px;border:1px solid #e2e8f0;">' +
                '<p style="margin:0 0 8px;font-size:12px;font-weight:600;color:#64748b;">Tu mensaje</p>' +
                '<div style="margin:0;font-size:14px;line-height:1.6;color:#1e293b;">' + bodyHtml + '</div>' +
                '</div>' +
                '<p style="margin:20px 0 0;font-size:12px;line-height:1.5;color:#94a3b8;">Este correo es automático. Si no enviaste el formulario, ignóralo.</p>' +
                '</td></tr></table></td></tr></table>'
            );
        }

        const form = document.getElementById('contact-form');
        if (form) {
        form.addEventListener('submit', function(event) {
            event.preventDefault();
            const btn = this.querySelector('button[type="submit"]');
            const originalContent = btn.innerHTML;
            setContactFormError('');
            btn.innerHTML = '<svg class="animate-spin" width="20" height="20" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none" stroke-dasharray="32" stroke-dashoffset="32"><animate attributeName="stroke-dashoffset" values="32;0" dur="1s" repeatCount="indefinite"/></circle></svg><span>Enviando...</span>';
            btn.disabled = true;

            const formData = new FormData(this);
            const senderName = String(formData.get('name') || '');
            const senderEmail = String(formData.get('email') || '');
            const senderSubject = String(formData.get('subject') || '');
            const senderMessage = String(formData.get('message') || '');

            const ownerMessageParams = {
                title: 'Portfolio Contact',
                to_email: ownerEmail,
                from_name: senderName,
                from_email: senderEmail,
                subject: senderSubject,
                message: buildOwnerHtml(senderName, senderEmail, senderSubject, senderMessage),
                name: senderName,
                email: senderEmail
            };

            const userAckParams = {
                title: 'Portfolio Contact',
                to_email: senderEmail,
                from_name: 'Sergio Elías',
                from_email: ownerEmail,
                subject: 'Gracias por tu mensaje · Portfolio',
                message: buildUserAckHtml(senderName, senderEmail, senderSubject, senderMessage),
                name: senderName,
                email: senderEmail
            };

            var formEl = this;
            emailjs.send(serviceId, template, ownerMessageParams)
                .then(function () { return emailjs.send(serviceId, template, userAckParams); })
                .then(function () {
                    formEl.reset();
                    btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg><span>¡Mensaje enviado!</span>';
                    btn.classList.remove('bg-primary');
                    btn.classList.add('bg-green-500');
                    setTimeout(function () {
                        btn.innerHTML = originalContent;
                        btn.disabled = false;
                        btn.classList.add('bg-primary');
                        btn.classList.remove('bg-green-500');
                    }, 3000);
                })
                .catch(function (error) {
                    console.log('FAILED...', error);
                    setContactFormError('No se pudo enviar el mensaje. Inténtalo de nuevo en unos minutos.');
                    btn.innerHTML = '<span>Error al enviar</span>';
                    btn.classList.remove('bg-primary');
                    btn.classList.add('bg-red-500');
                    setTimeout(function () {
                        btn.innerHTML = originalContent;
                        btn.disabled = false;
                        btn.classList.add('bg-primary');
                        btn.classList.remove('bg-red-500');
                    }, 3000);
                });
        });
        }
    </script>
</section>

<style>
    .section-shell {
        background: linear-gradient(180deg, #0a1628 0%, #0f2744 100%);
    }
    select option {
        background: #0f2744;
        color: white;
    }
</style>
