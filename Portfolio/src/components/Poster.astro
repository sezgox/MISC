---
import SectionNavButtons from "./SectionNavButtons.astro";
---

<section class="min-h-[100dvh] flex flex-col items-center justify-center px-4 md:px-8 py-10 md:py-0 relative overflow-hidden" id="poster">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <div class="absolute top-20 left-10 w-72 h-72 bg-primary/10 rounded-full blur-3xl animate-[float_6s_ease-in-out_infinite]"></div>
        <div class="absolute bottom-20 right-10 w-96 h-96 bg-cyan-500/10 rounded-full blur-3xl animate-[float_8s_ease-in-out_infinite_reverse]"></div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gradient-radial from-primary/5 to-transparent rounded-full"></div>
    </div>

    <div class="relative z-10 flex flex-col items-center gap-6 md:gap-8 max-w-5xl mx-auto text-center">
        <div class="relative">
            <div class="absolute inset-0 bg-gradient-to-r from-primary to-cyan-400 rounded-full blur-2xl opacity-30 animate-[pulse-glow_3s_ease-in-out_infinite]"></div>
            <img src="/pfp.png" alt="Sergio Elías" class="relative w-32 md:w-40 lg:w-48 h-auto rounded-full border-4 border-white/10 shadow-2xl">
        </div>

        <div class="space-y-3 md:space-y-4">
            <p class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-cyan-200/30 bg-cyan-300/10 text-cyan-100 text-xs md:text-sm tracking-wide">
                <span class="w-2 h-2 rounded-full bg-emerald-300 animate-pulse"></span>
                Disponible para nuevos retos fullstack
            </p>
            <h1 class="text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-bold bg-gradient-to-r from-white via-gray-200 to-cyan-100 bg-clip-text text-transparent animate-[gradient-shift_5s_ease_infinite] bg-[length:200%_auto]">
                Sergio Elías Zúñiga
            </h1>
            <h2 class="text-xl md:text-2xl lg:text-3xl font-medium text-cyan-200">
                Fullstack Developer
            </h2>
            <p class="text-slate-300 text-sm md:text-base max-w-2xl mx-auto leading-relaxed">
                Desarrollo producto digital end-to-end, desde la idea y la arquitectura hasta el despliegue y mantenimiento en producción.
            </p>
        </div>

        <div class="hero-strip w-full max-w-4xl rounded-2xl p-4 md:p-5 grid grid-cols-1 md:grid-cols-3 gap-3 text-left">
            <article class="hero-item">
                <p class="hero-kicker">Actualmente</p>
                <p class="hero-value">Niji</p>
                <p class="hero-sub">Full Stack Developer</p>
            </article>
            <article class="hero-item">
                <p class="hero-kicker">Cliente</p>
                <p class="hero-value">Air Liquide</p>
                <p class="hero-sub">Plataforma de salud digital</p>
            </article>
            <article class="hero-item">
                <p class="hero-kicker">Base tecnica</p>
                <p class="hero-value">Angular + Node</p>
                <p class="hero-sub">Microservicios y mantenimiento</p>
            </article>
        </div>

        <div class="flex flex-wrap justify-center gap-3 md:gap-4 mt-2">
            <img src="/ag.png" alt="Angular" class="w-8 md:w-10 lg:w-12 opacity-60 hover:opacity-100 transition-opacity" title="Angular">
            <img src="/ne.png" alt="NestJS" class="w-8 md:w-10 lg:w-12 opacity-60 hover:opacity-100 transition-opacity" title="NestJS">
            <img src="/net.png" alt=".NET" class="w-8 md:w-10 lg:w-12 opacity-60 hover:opacity-100 transition-opacity" title=".NET">
            <img src="/io.png" alt="Ionic" class="w-8 md:w-10 lg:w-12 opacity-60 hover:opacity-100 transition-opacity" title="Ionic">
        </div>
    </div>

    <nav class="relative z-10 mt-8 md:mt-10 w-full max-w-3xl">
        <SectionNavButtons />
    </nav>

    <div class="relative z-10 mt-7 md:mt-8 flex gap-4 md:gap-6">
        <a href="http://linkedin.com/in/seliaszg" target="_blank" rel="noopener noreferrer" class="social-link w-10 h-10 md:w-12 md:h-12 rounded-full bg-white/5 border border-white/10 flex items-center justify-center hover:border-primary hover:bg-primary/10 transition-all duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="md:w-5 md:h-5">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
        </a>
        <a href="https://github.com/sezgox" target="_blank" rel="noopener noreferrer" class="social-link w-10 h-10 md:w-12 md:h-12 rounded-full bg-white/5 border border-white/10 flex items-center justify-center hover:border-primary hover:bg-primary/10 transition-all duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="md:w-5 md:h-5">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
        </a>
    </div>
</section>

<style>
    .hero-strip {
        background:
            radial-gradient(100% 120% at 0% 0%, rgba(34, 211, 238, 0.16) 0%, rgba(34, 211, 238, 0) 45%),
            linear-gradient(140deg, rgba(15, 28, 49, 0.88), rgba(15, 23, 42, 0.74));
        border: 1px solid rgba(148, 163, 184, 0.26);
        box-shadow: 0 14px 38px rgba(2, 8, 23, 0.38);
        backdrop-filter: blur(8px);
    }

    .hero-item {
        padding: 0.4rem 0.45rem;
    }

    .hero-kicker {
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #a5f3fc;
    }

    .hero-value {
        font-size: 1.02rem;
        font-weight: 700;
        color: #f8fafc;
        margin-top: 0.2rem;
    }

    .hero-sub {
        font-size: 0.82rem;
        color: #cbd5e1;
        margin-top: 0.2rem;
    }

    .social-link:hover {
        transform: scale(1.1);
    }
</style>
