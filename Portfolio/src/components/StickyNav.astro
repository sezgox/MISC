---
import SectionNavButtons from "./SectionNavButtons.astro";
---

<div class="sticky-nav" id="sticky-nav">
  <nav class="sticky-nav__inner" aria-label="Secciones">
    <a href="#poster" class="sticky-nav__brand" aria-label="Ir arriba">
      <span class="sticky-nav__dot" aria-hidden="true"></span>
      Sergio Elías
    </a>
    <SectionNavButtons compact={true} />
  </nav>
</div>

<style>
  .sticky-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    padding: 0.85rem 1rem;
    background: rgba(5, 9, 19, 0.65);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(148, 163, 184, 0.16);
    transform: translateY(-120%);
    opacity: 0;
    pointer-events: none;
    transition: transform 240ms ease, opacity 240ms ease;
  }

  .sticky-nav.is-visible {
    transform: translateY(0);
    opacity: 1;
    pointer-events: auto;
  }

  .sticky-nav__inner {
    max-width: 72rem;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .sticky-nav__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #f8fafc;
    text-decoration: none;
    white-space: nowrap;
  }

  .sticky-nav__dot {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    background: linear-gradient(135deg, rgba(34, 211, 238, 1), rgba(16, 185, 129, 1));
    box-shadow: 0 0 26px rgba(34, 211, 238, 0.28);
  }

  :global(.sticky-nav .section-nav) {
    justify-content: flex-end;
  }

  @media (max-width: 520px) {
    .sticky-nav__brand {
      display: none;
    }
    .sticky-nav__inner {
      justify-content: center;
    }

    :global(.sticky-nav .section-nav) {
      justify-content: center;
    }
  }
</style>

