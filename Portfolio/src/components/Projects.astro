---
import ProjectCard, { type Project } from "./ProjectCard.astro";

const projects: Project[] = [
  {
    title: "Vente",
    description:
      "Aplicación principal de gestión de eventos con mapa, geolocalización, feed social y backend robusto. Uno de mis proyectos fullstack más completos en producto real.",
    technologies: ["Angular 18", "NestJS", "Prisma", "PostgreSQL", "Docker"],
    image: "/v.webp",
    link: "https://github.com/sezgox/venteweb",
    linkName: "Repositorio",
    category: "Proyectos principales"
  },
  {
    title: "Trips",
    description:
      "App para organizar viajes en grupo: solape de días libres, propuestas, comentarios y chat en tiempo real para tomar decisiones en una sola plataforma.",
    technologies: ["Angular", "NestJS", "Socket.IO", "PostgreSQL"],
    image: "/trip.webp",
    link: "https://trips.devogs.com",
    linkName: "Demo",
    category: "Proyectos principales"
  },
  {
    title: "Gael-Games",
    description:
      "Hub de minijuegos desarrollado con Phaser 3, con enfoque en experiencia fluida y visual para público infantil y familiar.",
    technologies: ["Phaser 3", "Vite", "JavaScript"],
    image: "/game.svg",
    link: "https://gael-games.devogs.com",
    linkName: "Demo",
    category: "Proyectos principales"
  },
  {
    title: "Devogs",
    description:
      "Plataforma personal para mostrar y servir mis apps: gestión de mi propio servidor, despliegues, dockerización y flujo DevOps para publicar proyectos reales.",
    technologies: ["Docker", "Nginx", "Cloudflare", "Deploy Automation", "DevOps"],
    image: "/devogs.svg",
    link: "https://devogs.com",
    linkName: "Plataforma",
    category: "Proyectos principales"
  },
  {
    title: "ShopApp",
    description:
      "Proyecto para afianzar Angular y NestJS: roles de usuario, guards y base para integrar pasarela de pago con Stripe.",
    technologies: ["Angular", "NestJS", "Prisma", "PostgreSQL", "Stripe"],
    image: "/mml.webp",
    link: "https://github.com/sezgox/MISC/tree/main/ShopApp",
    linkName: "Repositorio",
    category: "Proyectos de aprendizaje"
  },
  {
    title: "MoviesApp",
    description:
      "Proyecto con Angular y Express consumiendo APIs externas (TheMovieDB), búsqueda de contenido y prácticas de integración de servicios externos.",
    technologies: ["Angular", "Node.js", "Express", "API REST"],
    image: "/w.webp",
    link: "https://github.com/sezgox/MISC/tree/main/MoviesApp",
    linkName: "Repositorio",
    category: "Proyectos de aprendizaje"
  },
  {
    title: "NotesApp",
    description:
      "App de aprendizaje con Angular y Express para consolidar CRUD y autenticación en una arquitectura cliente-servidor sencilla.",
    technologies: ["Angular", "Node.js", "Express", "PostgreSQL"],
    image: "/post-it.webp",
    link: "https://github.com/sezgox/MISC/tree/main/NotesApp",
    linkName: "Repositorio",
    category: "Proyectos de aprendizaje"
  },
  {
    title: "CoffeeDashboard",
    description:
      "Servicio en planificación para restaurantes/cafeterías: órdenes para camareros y dueños, tickets, auth, registro de menús y gestión por apartados.",
    technologies: ["Servicio SaaS", "Auth", "Gestión de menús", "Órdenes y tickets"],
    image: "/coffee.svg",
    link: "#",
    category: "Próximamente"
  },
  {
    title: "Vibing",
    description:
      "Proyecto próximo orientado a música y experiencia interactiva, actualmente en evolución.",
    technologies: ["Node.js", "HTTP", "ES Modules"],
    image: "/vibing.svg",
    link: "#",
    category: "Próximamente"
  },
  {
    title: "GameDev Portfolio (cliente)",
    description:
      "Proyecto freelance para un desarrollador de videojuegos: sitio de presentacion mas dashboard privado para actualizar proyectos y contenido.",
    technologies: ["Angular", "Node.js", "MongoDB"],
    image: "/gamedev.svg",
    link: "https://juan-manuel-mateo.netlify.app/",
    linkName: "Demo",
    category: "Freelance"
  }
];

const sections = [
  { title: "Proyectos principales", icon: "producto real y despliegue", tone: "tone-cyan" },
  { title: "Proyectos de aprendizaje", icon: "base técnica y práctica", tone: "tone-violet" },
  { title: "Próximamente", icon: "servicios en construcción", tone: "tone-amber" },
  { title: "Freelance", icon: "trabajo con cliente real", tone: "tone-emerald" }
];
---

<section class="section-shell text-white px-6 md:px-12 lg:px-16 py-16 md:py-20" id="projects">

    <div class="projects-shell max-w-7xl mx-auto">
        <h2 class="font-bold text-3xl md:text-4xl lg:text-5xl mb-3">Proyectos</h2>
        <p class="text-slate-300 text-base md:text-lg mb-10 max-w-3xl">Selección curada entre producto real, aprendizaje y servicios próximos. Enfocada en impacto, stack y ejecución.</p>

        {sections.map((section) => {
          const items = projects.filter((project) => project.category === section.title);
          if (!items.length) return null;
          return (
            <section class="mb-12 section-frame">
              <h3 class={`text-xl md:text-2xl font-semibold mb-6 flex items-center gap-3 ${section.tone}`}>
                <span class="category-dot w-3 h-3 rounded-full"></span>
                {section.title}
                <span class="text-xs md:text-sm font-normal text-slate-400 ml-2">{section.icon}</span>
              </h3>
              <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4 md:gap-6">
                {items.map((project) => <ProjectCard project={project} />)}
              </div>
            </section>
          );
        })}
    </div>

    <a href="#contact" class="inline-flex px-6 py-3 bg-primary rounded-lg font-semibold items-center gap-2 ml-auto mt-8 hover:bg-primary/90 transition-colors">
        Contacto
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"/>
            <path d="m12 5 7 7-7 7"/>
        </svg>
    </a>
</section>

<style>
    .section-shell {
        background:
          radial-gradient(120% 140% at 10% 0%, rgba(56, 189, 248, 0.16) 0%, rgba(56, 189, 248, 0) 42%),
          linear-gradient(180deg, #060b17 0%, #0b1730 55%, #0f1f3a 100%);
    }

    .projects-shell {
      position: relative;
    }

    .section-frame {
      padding: 1rem 1rem 1.2rem;
      border: 1px solid rgba(148, 163, 184, 0.18);
      border-radius: 1rem;
      background: linear-gradient(135deg, rgba(15, 23, 42, 0.42), rgba(15, 23, 42, 0.1));
      backdrop-filter: blur(8px);
    }

    .tone-cyan .category-dot { background: #22d3ee; }
    .tone-violet .category-dot { background: #a78bfa; }
    .tone-amber .category-dot { background: #f59e0b; }
    .tone-emerald .category-dot { background: #34d399; }
</style>
