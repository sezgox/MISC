generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  Pending
  Tripper
  Admin
}

enum TripRole {
  Accommodation
  Transport
  Visits
}

enum TripStatus {
  Planning
  Closed
  Discarded
}

enum ProposalType {
  Accommodation
  Transport
  Visit
}

enum ProposalStatus {
  Proposed
  Accepted
  Denied
}

model User {
  username       String               @id
  password       String
  profilePicture String
  groupId        String
  userRole       UserRole             @default(Pending)
  group          Group                @relation(fields: [groupId], references: [id], onDelete: Restrict)
  plannedTrips   Trip[]               @relation("TripPlanner")
  comments       Comment[]
  freeDays       FreeDays[]
  participates   Participant[]
  tripRoles      TripRoleAssignment[]
  proposals      Proposal[]           @relation("ProposalAuthor")
  proposalVotes  ProposalVote[]
  messages       ChatMessage[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
}

model Group {
  id        String        @id
  name      String
  members   User[]
  trips     Trip[]
  messages  ChatMessage[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Trip {
  id                              Int                  @id @default(autoincrement())
  groupId                         String
  plannerUsername                 String
  name                            String
  destination                     String
  details                         String?
  budget                          Int?
  status                          TripStatus           @default(Planning)
  startDate                       DateTime
  endDate                         DateTime
  acceptedAccommodationProposalId Int?                 @unique
  acceptedTransportProposalId     Int?                 @unique
  acceptedVisitProposalId         Int?                 @unique
  group                           Group                @relation(fields: [groupId], references: [id], onDelete: Restrict)
  planner                         User                 @relation("TripPlanner", fields: [plannerUsername], references: [username], onDelete: Restrict)
  comments                        Comment[]
  participants                    Participant[]
  tripRoles                       TripRoleAssignment[]
  proposals                       Proposal[]
  acceptedAccommodationProposal   Proposal?            @relation("AcceptedAccommodationProposal", fields: [acceptedAccommodationProposalId], references: [id], onDelete: SetNull)
  acceptedTransportProposal       Proposal?            @relation("AcceptedTransportProposal", fields: [acceptedTransportProposalId], references: [id], onDelete: SetNull)
  acceptedVisitProposal           Proposal?            @relation("AcceptedVisitProposal", fields: [acceptedVisitProposalId], references: [id], onDelete: SetNull)
  createdAt                       DateTime             @default(now())
  updatedAt                       DateTime             @updatedAt

  @@index([groupId, status])
}

model Participant {
  userId    String
  tripId    Int
  user      User     @relation(fields: [userId], references: [username], onDelete: Cascade)
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, tripId])
}

model TripRoleAssignment {
  tripId    Int
  userId    String
  role      TripRole
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [username], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([tripId, userId, role])
}

model Proposal {
  id                          Int                           @id @default(autoincrement())
  tripId                      Int
  createdByUsername           String
  type                        ProposalType
  status                      ProposalStatus                @default(Proposed)
  details                     String?
  trip                        Trip                          @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdBy                   User                          @relation("ProposalAuthor", fields: [createdByUsername], references: [username], onDelete: Cascade)
  votes                       ProposalVote[]
  accommodationItems          AccommodationProposalObject[]
  transportItems              TransportProposalObject[]
  visitItems                  VisitProposalObject[]
  acceptedAccommodationInTrip Trip?                         @relation("AcceptedAccommodationProposal")
  acceptedTransportInTrip     Trip?                         @relation("AcceptedTransportProposal")
  acceptedVisitInTrip         Trip?                         @relation("AcceptedVisitProposal")
  createdAt                   DateTime                      @default(now())
  updatedAt                   DateTime                      @updatedAt

  @@index([tripId, type])
}

model ProposalVote {
  proposalId Int
  userId     String
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [username], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@id([proposalId, userId])
}

model AccommodationProposalObject {
  id                  Int      @id @default(autoincrement())
  proposalId          Int
  name                String
  place               String
  nights              Int
  pricePerPersonCents Int
  referenceLink       String?
  details             String?
  proposal            Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model TransportProposalObject {
  id                  Int      @id @default(autoincrement())
  proposalId          Int
  name                String
  origin              String
  destination         String
  pricePerPersonCents Int
  referenceLink       String?
  details             String?
  proposal            Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model VisitProposalObject {
  id                  Int      @id @default(autoincrement())
  proposalId          Int
  name                String
  category            String
  scheduledAt         DateTime
  durationMinutes     Int
  pricePerPersonCents Int
  referenceLink       String?
  details             String?
  proposal            Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Comment {
  id        Int      @id @default(autoincrement())
  tripId    Int
  userId    String
  comment   String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [username], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model FreeDays {
  id        Int      @id @default(autoincrement())
  username  String
  startDate DateTime
  endDate   DateTime
  user      User     @relation(fields: [username], references: [username], onDelete: Cascade)
}

model ChatMessage {
  id      Int      @id @default(autoincrement())
  userId  String
  message String
  chatId  String
  date    DateTime @default(now())
  user    User     @relation(fields: [userId], references: [username], onDelete: Cascade)
  group   Group    @relation(fields: [chatId], references: [id], onDelete: Cascade)
}
