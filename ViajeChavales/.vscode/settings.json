  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  "search.exclude": {
    "**/.codex-orchestration/handoffs/*.md": true,
    "**/agent-transcripts/**": true
  }
}
