APP_PORT=8091
# Host port for the Trips-only gateway (trips-gateway). Public multi-host routing uses infra/ingress (default INGRESS_PORT=8090) and Cloudflare → devogs-ingress:80.

POSTGRES_DB=viajechavales
POSTGRES_USER=viajechavales
POSTGRES_PASSWORD=change-me

# Must match the password embedded in DATABASE_URL used by the backend (compose interpolates from POSTGRES_*).
# If you change POSTGRES_PASSWORD in CI without recreating the Postgres volume (or without ALTER USER),
# Prisma will fail with P1000 (authentication failed). Keep secret, DATABASE_URL, and volume state aligned.

JWT_SECRET=change-this-super-secret
JWT_EXPIRES=7d
JWT_ISSUER=ViajeChavales
JWT_AUDIENCE=ViajeChavalesUsers

# Tunnel token: use PWs/infra/cloudflare-tunnel/.env (see .env.example there). Legacy fallback only:
# CLOUDFLARED_TUNNEL_TOKEN=
# Optional helper so scripts can print final public URL (example: trips.example.com)
CLOUDFLARE_PUBLIC_HOSTNAME=
