# Named tunnel token (Cloudflare Zero Trust → Networks → Tunnels → your tunnel → Docker).
# Copy this file to .env in this folder (gitignored) and paste the token.
#
# In the tunnel's "Public hostname routes", every hostname (apex, trips, gael-games,
# portfolio subdomain, etc.) must point to the shared ingress origin:
#   http://devogs-ingress:80
# Do NOT use http://gateway:80 — see ViajeChavales/docs/cloudflare-tunnel.md section 6.1.
#
CLOUDFLARED_TUNNEL_TOKEN=
